<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Task_Manager.Views.Tasks.TasksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding Title}">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="16">

            <Entry
                Placeholder="Task Title"
                Text="{Binding TaskTitle}" />

            <Editor
                Placeholder="Description"
                AutoSize="TextChanges"
                HeightRequest="100"
                Text="{Binding Description}" />

            <DatePicker
                Date="{Binding DueDate}" />

            <Picker
                Title="Priority"
                SelectedItem="{Binding Priority}">

                <x:String>Low</x:String>
                <x:String>Medium</x:String>
                <x:String>High</x:String>

            </Picker>

            <Button
                Text="Add Task"
                Command="{Binding AddTaskCommand}" />

            <CollectionView
                ItemsSource="{Binding Tasks}">

                <CollectionView.EmptyView>

                    <VerticalStackLayout
                        Padding="30">

                        <Label
                            HorizontalOptions="Center"
                            Text="No tasks yet." />

                    </VerticalStackLayout>

                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Frame
                            Margin="0,5"
                            Padding="15">

                            <VerticalStackLayout>

                                <Label
                                    FontAttributes="Bold"
                                    FontSize="18"
                                    Text="{Binding Title}" />

                                <Label
                                    Text="{Binding Description}" />

                                <Label
                                    FontSize="12"
                                    Text="{Binding DueDate}" />

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>