<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Task_Manager.Views.Tasks.TasksPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding Title}"
    BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundColorLight}, Dark={StaticResource PageBackgroundColorDark}}">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="16">

            <Entry
                Placeholder="Task Title"
                Text="{Binding TaskTitle}"
                BackgroundColor="{AppThemeBinding Light={StaticResource InputBackgroundColorLight}, Dark={StaticResource InputBackgroundColorDark}}"
                TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>

            <Editor
                Placeholder="Description"
                AutoSize="TextChanges"
                HeightRequest="100"
                Text="{Binding Description}"
                BackgroundColor="{AppThemeBinding Light={StaticResource InputBackgroundColorLight}, Dark={StaticResource InputBackgroundColorDark}}"
                TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>

            <DatePicker
                Date="{Binding DueDate}"
                TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>

            <Picker
                x:Name="PriorityPicker"
                Title="Priority"
                SelectedItem="{Binding Priority}"
                TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>

            <Button
                Text="Add Task"
                Command="{Binding AddTaskCommand}"/>

            <CollectionView
                ItemsSource="{Binding Tasks}">

                <CollectionView.EmptyView>

                    <VerticalStackLayout
                        Padding="30">

                        <Label
                            HorizontalOptions="Center"
                            Text="No tasks yet."
                            TextColor="{AppThemeBinding Light={StaticResource TextColorSecondaryLight}, Dark={StaticResource TextColorSecondaryDark}}"/>

                    </VerticalStackLayout>

                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem
                                        Text="Delete"
                                        BackgroundColor="Red"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteTaskCommand}"
                                        CommandParameter="{Binding .}"/>
                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame
                                Margin="0,5"
                                Padding="15"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackgroundColorLight}, Dark={StaticResource CardBackgroundColorDark}}"
                                BorderColor="{AppThemeBinding Light={StaticResource BorderColorLight}, Dark={StaticResource BorderColorDark}}">

                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10">

                                    <CheckBox
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.RowSpan="4"
                                        VerticalOptions="Center"
                                        IsChecked="{Binding IsCompleted}"
                                        CheckedChanged="OnTaskCheckedChanged"/>

                                    <Label
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        FontAttributes="Bold"
                                        FontSize="18"
                                        Text="{Binding Title}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextColorLight}, Dark={StaticResource TextColorDark}}"/>

                                    <Label
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Text="{Binding Description}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextColorSecondaryLight}, Dark={StaticResource TextColorSecondaryDark}}"/>

                                    <HorizontalStackLayout
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Spacing="10">

                                        <Label
                                            FontSize="12"
                                            Text="{Binding DueDate, StringFormat='Due: {0:MMM dd, yyyy}'}"
                                            TextColor="{AppThemeBinding Light={StaticResource TextColorSecondaryLight}, Dark={StaticResource TextColorSecondaryDark}}"/>

                                        <Label
                                            FontSize="12"
                                            FontAttributes="Bold"
                                            Text="OVERDUE"
                                            TextColor="{StaticResource OverdueColor}"
                                            IsVisible="{Binding IsOverdue}"/>

                                    </HorizontalStackLayout>

                                    <Label
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        FontSize="12"
                                        FontAttributes="Bold"
                                        Text="{Binding Priority, StringFormat='Priority: {0}'}"
                                        TextColor="{AppThemeBinding Light={StaticResource TextColorSecondaryLight}, Dark={StaticResource TextColorSecondaryDark}}"/>

                                    <Button
                                        Grid.Row="0"
                                        Grid.Column="2"
                                        Grid.RowSpan="4"
                                        Text="Edit"
                                        VerticalOptions="Center"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditTaskCommand}"
                                        CommandParameter="{Binding .}"/>

                                </Grid>

                            </Frame>

                        </SwipeView>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>